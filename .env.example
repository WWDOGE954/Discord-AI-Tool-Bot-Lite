# Discord

DISCORD_TOKEN=

# Optional: restrict commands/mentions to one channel. Use 0 to allow all channels.

TARGET_CHANNEL_ID=0

# Optional: faster command sync while testing. Use 0 for global commands.

GUILD_ID=0

# Optional mention reply mode. Slash commands always work.

REPLY_ON_MENTION=true

# AI API provider

# Currently supported: openai_compatible

AI_PROVIDER=openai_compatible

# Examples:

# OpenAI: https://api.openai.com/v1

# OpenRouter: https://openrouter.ai/api/v1

# DeepSeek: https://api.deepseek.com/v1

AI_API_BASE_URL=https://openrouter.ai/api/v1
AI_API_KEY=
AI_MODEL=openrouter/free

AI_TEMPERATURE=0.7
AI_MAX_TOKENS=800
AI_TIMEOUT_SECONDS=60
SYSTEM_PROMPT="You are a helpful Discord AI assistant. Keep replies clear, safe, and concise."

# Tool architecture mode

# router   = traditional decoupled tool router

# mcp_like = MCP-like tool registry demo, not a full MCP server

TOOL_MODE=mcp_like

# Memory mode

# none = no conversation memory

# temp = temporary RAM memory, cleared when bot restarts

MEMORY_MODE=temp
MAX_MEMORY_PER_USER=10

# Token usage mode

# disabled / api / estimate / api_or_estimate

USAGE_MODE=api_or_estimate
USAGE_LOG_FILE=usage_logs.jsonl
